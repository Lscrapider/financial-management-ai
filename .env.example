# Compose env selection
COMPOSE_ENV_FILE=../.env
URBAN_SIDEQUEST_SKIP_ENV_FILE=0

# PostgreSQL
POSTGRES_HOST=common-postgres
POSTGRES_PORT=5432
POSTGRES_DB=finance_management
POSTGRES_ADMIN_DATABASE=postgres
POSTGRES_URL=jdbc:postgresql://common-postgres:5432/finance_management
POSTGRES_USERNAME=
POSTGRES_ADMIN_USER=
POSTGRES_ADMIN_PASSWORD=
POSTGRES_USER=
POSTGRES_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=common-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_ADMIN_USER=
RABBITMQ_ADMIN_PASSWORD=
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=finance

# InfluxDB
INFLUXDB_URL=http://common-influxdb:8086
INFLUXDB_ORG=finance
INFLUXDB_BUCKET=stock_intraday
COMMON_INFLUXDB_ADMIN_TOKEN=
INFLUXDB_TOKEN=

# MinIO
MINIO_ENDPOINT=http://common-minio:9000
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_USER=
MINIO_PASSWORD=

# External APIs
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
TUSHARE_BASE_URL=https://api.tushare.pro
TUSHARE_TOKEN=

# Mail
MAIL_HOST=
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=

# Security
JWT_SECRET=

# Internal service URLs
AGENT_CALLBACK_URL=http://finance-service:8081/finance-api/internal/agent/callback
AGENT_DATA_GATEWAY_URL=http://finance-service:8081/finance-api/internal/agent/data/query
FINANCE_API_BASE_URL=http://finance-service:8081/finance-api
BACKEND_PROXY_TARGET=http://finance-service:8081
FRONTEND_PORT=5777
